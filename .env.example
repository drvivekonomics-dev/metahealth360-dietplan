# Copy this file to `.env` and fill in the real values.
# Expo injects env vars prefixed with EXPO_PUBLIC_ into your app bundle at build time.

# Firebase config — from Firebase console → metahealth360 → Project settings →
# General → Web apps → "MetaHealth360 Doctor Portal" → SDK setup → Config.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# From Google Cloud Console → APIs & Services → Credentials → OAuth Client ID (Web)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=

# From Google Cloud Console → OAuth Client ID (Android) — created after first EAS build
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Optional — only if you also build an iOS client
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
