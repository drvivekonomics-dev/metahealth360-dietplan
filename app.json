{
  "expo": {
    "name": "MetaHealth360 Diet Plan",
    "slug": "metahealth360-dietplan",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "metahealth360dietplan",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0B6E4F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.raskar.metahealth360.dietplan"
    },
    "android": {
      "package": "com.raskar.metahealth360.dietplan",
      "adaptiveIcon": {
        "backgroundColor": "#0B6E4F"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-sharing",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": false
    }
  }
}
